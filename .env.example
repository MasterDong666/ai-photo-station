# 复制为 .env 后填写；云服务器上建议用 .env 或系统环境变量，勿提交 .env

# 服务端口（默认 3000）
PORT=3000
# 监听地址：云服务器填 0.0.0.0，本地可省略（直接 node server.js 时默认已是 0.0.0.0）
HOST=0.0.0.0

# Gemini 图像生成 API Key（必填）
GEMINI_KEY=your_gemini_api_key_here

# SQLite 数据库文件路径（可选，默认项目根目录 users.db）
# DB_PATH=/var/app/ai-photo-station/users.db

# 免费用户每日生成次数（可选，默认 3）
# FREE_DAILY_LIMIT=3

# bcrypt 加密轮数（可选，默认 10）
# BCRYPT_ROUNDS=10
